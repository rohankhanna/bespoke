  "candidate_definitions": [
    {
      "source_kind": "repo-description",
      "source_repo": "micromatch/picomatch",
      "status": "candidate-context",
      "text": "Blazing fast and accurate glob matcher written JavaScript, with no dependencies and full support for standard and extended Bash glob features, including braces, extglobs, POSIX brackets, and regular expressions. Used by GraphQL, Jest, Astro, Snowpack, Storybook, bulma, Serverless, fdir, Netlify, AWS Amplify, Revogrid, rollup, routify, open-wc, imba, ava, docusaurus, fast-glob, globby, chokidar, anymatch, cloudflare/miniflare, pts, and more than 5 million projects! Please follow picomatch's author: https://github.com/jonschlinkert"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "micromatch/picomatch",
      "status": "candidate-context",
      "text": "<h1 align=\"center\">Picomatch</h1>"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "kkos/oniguruma",
      "status": "candidate-context",
      "text": "regular expression library"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "kkos/oniguruma",
      "status": "candidate-context",
      "text": "Oniguruma"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "micromatch/expand-brackets",
      "status": "candidate-context",
      "text": "Expand POSIX bracket expressions (character classes) in glob patterns."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "micromatch/expand-brackets",
      "status": "candidate-context",
      "text": "> Expand POSIX bracket expressions (character classes) in glob patterns."
    },
    {
      "source_kind": "repo-description",
      "source_repo": "micromatch/is-glob",
      "status": "candidate-context",
      "text": "If you use globs, this will make your code faster. Returns `true` if the given string looks like a glob pattern or an extglob pattern. This makes it easy to create code that only uses external modules like node-glob when necessary, resulting in much faster code execution and initialization time, and a better user experience. 55+ million downloads. "
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "micromatch/is-glob",
      "status": "candidate-context",
      "text": "> Returns `true` if the given string looks like a glob pattern or an extglob pattern. This makes it easy to create code that only uses external modules like node-glob when necessary, resulting in much faster code execution and initialization time, and a better user experience."
    },
    {
      "source_kind": "repo-description",
      "source_repo": "rust-lang/regex",
      "status": "candidate-context",
      "text": "An implementation of regular expressions for Rust. This implementation uses finite automata and guarantees linear time matching on all inputs."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "rust-lang/regex",
      "status": "candidate-context",
      "text": "regex"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "dlclark/regexp2",
      "status": "candidate-context",
      "text": "A full-featured regex engine in pure Go based on the .NET engine"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "dlclark/regexp2",
      "status": "candidate-context",
      "text": "Regexp2 is a feature-rich RegExp engine for Go. It doesn't have constant time guarantees like the built-in `regexp` package, but it allows backtracking and is compatible with Perl5 and .NET. You'll likely be better off with the RE2 engine from the `regexp` package and should onl\u2026"
    }
  ],
