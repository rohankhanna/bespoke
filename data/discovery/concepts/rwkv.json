  "candidate_definitions": [
    {
      "source_kind": "repo-description",
      "source_repo": "josStorer/RWKV-Runner",
      "status": "candidate-context",
      "text": "A RWKV management and startup tool, full automation, only 8MB. And provides an interface compatible with the OpenAI API. RWKV is a large language model that is fully open source and available for commercial use."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "josStorer/RWKV-Runner",
      "status": "candidate-context",
      "text": "<p align=\"center\">"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "BlinkDL/RWKV-LM",
      "status": "candidate-context",
      "text": "RWKV (pronounced RwaKuv) is an RNN with great LLM performance, which can also be directly trained like a GPT transformer (parallelizable). We are at RWKV-7 \"Goose\". So it's combining the best of RNN and transformer - great performance, linear time, constant space (no kv-cache), fast training, infinite ctx_len, and free sentence embedding."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "BlinkDL/RWKV-LM",
      "status": "candidate-context",
      "text": "RWKV website: https://rwkv.com (with 150+ papers training various RWKV models)"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "BlinkDL/ChatRWKV",
      "status": "candidate-context",
      "text": "ChatRWKV is like ChatGPT but powered by RWKV (100% RNN) language model, and open source."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "BlinkDL/ChatRWKV",
      "status": "candidate-context",
      "text": "RWKV-7 code: https://github.com/BlinkDL/RWKV-LM/tree/main/RWKV-v7"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "Ai00-X/ai00_server",
      "status": "candidate-context",
      "text": "The all-in-one RWKV runtime box with embed, RAG, AI agents, and more."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "Ai00-X/ai00_server",
      "status": "candidate-context",
      "text": "<p align='center'>"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "wenda-LLM/wenda",
      "status": "candidate-context",
      "text": "\u95fb\u8fbe\uff1a\u4e00\u4e2aLLM\u8c03\u7528\u5e73\u53f0\u3002\u76ee\u6807\u4e3a\u9488\u5bf9\u7279\u5b9a\u73af\u5883\u7684\u9ad8\u6548\u5185\u5bb9\u751f\u6210\uff0c\u540c\u65f6\u8003\u8651\u4e2a\u4eba\u548c\u4e2d\u5c0f\u4f01\u4e1a\u7684\u8ba1\u7b97\u8d44\u6e90\u5c40\u9650\u6027\uff0c\u4ee5\u53ca\u77e5\u8bc6\u5b89\u5168\u548c\u79c1\u5bc6\u6027\u95ee\u9898"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "wenda-LLM/wenda",
      "status": "candidate-context",
      "text": "\u672c\u9879\u76ee\u8bbe\u8ba1\u76ee\u6807\u4e3a\u5b9e\u73b0\u9488\u5bf9\u7279\u5b9a\u73af\u5883\u7684\u9ad8\u6548\u5185\u5bb9\u751f\u6210\uff0c\u540c\u65f6\u8003\u8651\u4e2a\u4eba\u548c\u4e2d\u5c0f\u4f01\u4e1a\u7684\u8ba1\u7b97\u8d44\u6e90\u5c40\u9650\u6027\uff0c\u4ee5\u53ca\u77e5\u8bc6\u5b89\u5168\u548c\u79c1\u5bc6\u6027\u95ee\u9898\u3002\u4e3a\u8fbe\u76ee\u6807\uff0c\u5e73\u53f0\u5316\u96c6\u6210\u4e86\u4ee5\u4e0b\u80fd\u529b\uff1a"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "RWKV/rwkv.cpp",
      "status": "candidate-context",
      "text": "INT4/INT5/INT8 and FP16 inference on CPU for RWKV language model"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "RWKV/rwkv.cpp",
      "status": "candidate-context",
      "text": "This is a port of [BlinkDL/RWKV-LM](https://github.com/BlinkDL/RWKV-LM) to [ggerganov/ggml](https://github.com/ggerganov/ggml)."
    },
    {
      "source_kind": "repo-description",
      "source_repo": "Atome-FE/llama-node",
      "status": "candidate-context",
      "text": "Believe in AI democratization. llama for nodejs backed by llama-rs, llama.cpp and rwkv.cpp, work locally on your laptop CPU. support llama/alpaca/gpt4all/vicuna/rwkv model."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "Atome-FE/llama-node",
      "status": "candidate-context",
      "text": "<div align=\"center\">"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "seasonjs/rwkv",
      "status": "candidate-context",
      "text": "pure go for rwkv"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "seasonjs/rwkv",
      "status": "candidate-context",
      "text": "pure go for rwkv and support cross-platform."
    },
    {
      "source_kind": "repo-description",
      "source_repo": "KerfuffleV2/smolrsrwkv",
      "status": "candidate-context",
      "text": "A relatively basic implementation of RWKV in Rust written by someone with very little math and ML knowledge. Supports 32, 8 and 4 bit evaluation. It can also directly load PyTorch RWKV models."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "KerfuffleV2/smolrsrwkv",
      "status": "candidate-context",
      "text": "An example of the RWKV approach to language models written in Rust by someone that"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "donomii/go-rwkv.cpp",
      "status": "candidate-context",
      "text": "A go wrapper around the rwkv.cpp library"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "donomii/go-rwkv.cpp",
      "status": "candidate-context",
      "text": "gowrkv.go is a wrapper around [rwkv-cpp](https://github.com/saharNooby/rwkv.cpp), which is an adaption of ggml.cpp."
    },
    {
      "source_kind": "repo-description",
      "source_repo": "guinmoon/LLMFarm",
      "status": "candidate-context",
      "text": "llama and other  large language models on iOS and MacOS offline using GGML library."
    },
    {
      "source_kind": "source-snippet",
