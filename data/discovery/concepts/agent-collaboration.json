    {
      "source_kind": "repo-description",
      "source_repo": "lobehub/lobehub",
      "status": "candidate-context",
      "text": "The ultimate space for work and life \u2014 to find, build, and collaborate with agent teammates that grow with you. We are taking agent harness to the next level \u2014 enabling multi-agent collaboration, effortless agent team design, and introducing agents as the unit of work interaction."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "lobehub/lobehub",
      "status": "candidate-context",
      "text": "<div align=\"center\"><a name=\"readme-top\"></a>"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "MinimalFuture/AgentMesh",
      "status": "candidate-context",
      "text": "A Multi-Agent framework that enables AI agents to collaborate effectively, helping you build powerful agent teams for solving complex tasks."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "MinimalFuture/AgentMesh",
      "status": "candidate-context",
      "text": "<p align=\"center\"><img src= \"https://github.com/user-attachments/assets/33d7a875-f64d-422f-8b51-68fb420c81e2\" alt=\"AgentMesh\" width=\"450\" /></p>"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "lobehub/lobehub",
      "status": "candidate-context",
      "text": "LobeHub organizes your agents into 7\u00d724 operation. It hires, schedules, reports on your entire AI team. You stay in charge \u2014 without staying online."
    },
    {
      "source_kind": "repo-description",
      "source_repo": "lobehub/lobehub",
      "status": "candidate-context",
      "text": "\ud83e\udd2f LobeHub is your Chief Agent Operator, organizing your agents into 7\u00d724 operations by hiring, scheduling, and reporting on your entire AI team."
    }
