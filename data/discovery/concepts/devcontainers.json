    {
      "source_kind": "repo-description",
      "source_repo": "microsoft/vscode-dev-containers",
      "status": "candidate-context",
      "text": "NOTE: Most of the contents of this repository have been migrated to the new devcontainers GitHub org (https://github.com/devcontainers). See https://github.com/devcontainers/template-starter and https://github.com/devcontainers/feature-starter for information on creating your own!"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "microsoft/vscode-dev-containers",
      "status": "candidate-context",
      "text": "**IMPORTANT NOTE: Dev containers have a new, expanded home in the [dev containers GitHub org](https://github.com/devcontainers)! We're so excited to connect with you there. To learn more, you can check out our [migration announcement](https://github.com/microsoft/vscode-dev-cont\u2026"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "devcontainers/cli",
      "status": "candidate-context",
      "text": "A reference implementation for the specification that can create and configure a dev container from a devcontainer.json."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "devcontainers/cli",
      "status": "candidate-context",
      "text": "This repository holds the dev container CLI, which can take a devcontainer.json and create and configure a dev container from it."
    },
    {
      "source_kind": "repo-description",
      "source_repo": "devcontainers/feature-starter",
      "status": "candidate-context",
      "text": "A  bootstrap repo for self-authoring Dev Container Features"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "devcontainers/feature-starter",
      "status": "candidate-context",
      "text": "> This repo provides a starting point and example for creating your own custom [dev container Features](https://containers.dev/implementors/features/), hosted for free on GitHub Container Registry. The example in this repository follows the [dev container Feature distribution sp\u2026"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "devcontainers/features",
      "status": "candidate-context",
      "text": "A collection of Dev Container Features managed by Dev Container spec maintainers. See https://github.com/devcontainers/feature-starter to publish your own"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "devcontainers/features",
