      "text": "<table style=\"width: 100%; border-style: none;\"><tr>"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "devcontainers/images",
      "status": "candidate-context",
      "text": "Repository for pre-built dev container images published under mcr.microsoft.com/devcontainers"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "devcontainers/images",
      "status": "candidate-context",
      "text": "<table style=\"width: 100%; border-style: none;\"><tr>"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "devcontainers/spec",
      "status": "candidate-context",
      "text": "Development Containers: Use a container as a full-featured development environment."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "devcontainers/spec",
      "status": "candidate-context",
      "text": "This repository is for the Development Container Specification. You can check out the spec on our website https://containers.dev/ too."
    },
    {
      "source_kind": "repo-description",
      "source_repo": "devcontainers/devcontainers.github.io",
