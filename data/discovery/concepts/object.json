    {
      "source_kind": "repo-description",
      "source_repo": "jonschlinkert/clone-deep",
      "status": "candidate-context",
      "text": "Recursively (deep) clone JavaScript native types, like Object, Array, RegExp, Date as well as primitives. Used by superstruct, merge-deep, and many others!"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "jonschlinkert/clone-deep",
      "status": "candidate-context",
      "text": "> Recursively (deep) clone JavaScript native types, like Object, Array, RegExp, Date as well as primitives."
    },
    {
      "source_kind": "repo-description",
      "source_repo": "jonschlinkert/is-plain-object",
      "status": "candidate-context",
      "text": "Returns true if the given value is an object created by the Object constructor."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "jonschlinkert/is-plain-object",
      "status": "candidate-context",
      "text": "> Returns true if an object was created by the `Object` constructor, or Object.create(null)."
    },
    {
      "source_kind": "repo-description",
      "source_repo": "jonschlinkert/isobject",
      "status": "candidate-context",
      "text": "Is the value an object, and not an array or null?"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "jonschlinkert/isobject",
      "status": "candidate-context",
      "text": "> Returns true if the value is an object and not an array or null."
    },
    {
      "source_kind": "repo-description",
      "source_repo": "jonschlinkert/kind-of",
      "status": "candidate-context",
      "text": "Get the native JavaScript type of a value, fast. Used by superstruct, micromatch and many others!"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "jonschlinkert/kind-of",
      "status": "candidate-context",
      "text": "> Get the native type of a value."
    },
    {
      "source_kind": "repo-description",
      "source_repo": "jonschlinkert/shallow-clone",
      "status": "candidate-context",
      "text": "Make a shallow clone of an object, array or primitive."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "jonschlinkert/shallow-clone",
      "status": "candidate-context",
      "text": "> Creates a shallow clone of any JavaScript value."
    },
    {
      "source_kind": "repo-description",
      "source_repo": "jonschlinkert/assign-deep",
      "status": "candidate-context",
      "text": "Deeply assign the enumerable properties of source objects to a destination object."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "jonschlinkert/assign-deep",
      "status": "candidate-context",
      "text": "> Deeply assign the values of all enumerable-own-properties and symbols from one or more source objects to a target object. Returns the target object."
    },
    {
      "source_kind": "repo-description",
      "source_repo": "jonschlinkert/omit-deep",
