  "candidate_definitions": [
    {
      "source_kind": "repo-description",
      "source_repo": "koide3/fast_gicp",
      "status": "candidate-context",
      "text": "A collection of GICP-based fast point cloud registration algorithms"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "koide3/fast_gicp",
      "status": "candidate-context",
      "text": "We released [small_gicp](https://github.com/koide3/small_gicp) that is twice as fast as fast_gicp and with minimum dependencies and clean interfaces."
    },
    {
      "source_kind": "repo-description",
      "source_repo": "koide3/ndt_omp",
      "status": "candidate-context",
      "text": "Multi-threaded and SSE friendly NDT algorithm"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "koide3/ndt_omp",
      "status": "candidate-context",
      "text": "This package provides an OpenMP-boosted Normal Distributions Transform (and GICP) algorithm derived from pcl. The NDT algorithm is modified to be SSE-friendly and multi-threaded. It can run up to 10 times faster than its original version in pcl."
    },
    {
      "source_kind": "repo-description",
      "source_repo": "koide3/small_gicp",
      "status": "candidate-context",
      "text": "Efficient and parallel algorithms for point cloud registration [C++, Python]"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "koide3/small_gicp",
      "status": "candidate-context",
      "text": "**small_gicp** is a header-only C++ library providing efficient and parallelized algorithms for fine point cloud registration (ICP, Point-to-Plane ICP, GICP, VGICP, etc.). It is a refined and optimized version of its predecessor, [fast_gicp](https://github.com/SMRT-AIST/fast_gic\u2026"
    }
  ],
