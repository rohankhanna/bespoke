    {
      "source_kind": "repo-description",
      "source_repo": "Fil/d3-geo-voronoi",
      "status": "candidate-context",
      "text": "Voronoi / Delaunay tessellations on the sphere"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "Fil/d3-geo-voronoi",
      "status": "candidate-context",
      "text": "This module adapts [d3-delaunay](https://github.com/d3/d3-delaunay) for spherical data. Given a set of objects in spherical coordinates, it computes their Delaunay triangulation and its dual, the Voronoi diagram."
