      "source_kind": "repo-description",
      "source_repo": "deluan/zsh-in-docker",
      "status": "candidate-context",
      "text": "Install Zsh, Oh My Zsh and plugins inside a Docker container with one line!"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "deluan/zsh-in-docker",
      "status": "candidate-context",
      "text": "[![Last Release](https://img.shields.io/github/v/release/deluan/zsh-in-docker?label=latest&style=flat-square)](https://github.com/deluan/zsh-in-docker/releases/latest)"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "spaceship-prompt/spaceship-prompt",
      "status": "candidate-context",
      "text": "\ud83d\ude80\u2728 Minimalistic, powerful and extremely customizable Zsh prompt"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "spaceship-prompt/spaceship-prompt",
