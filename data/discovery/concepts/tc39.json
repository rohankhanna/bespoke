      "source_repo": "babel/proposals",
      "status": "candidate-context",
      "text": "\u270d\ufe0f Tracking the status of Babel's implementation of TC39 proposals (may be out of date)"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "babel/proposals",
      "status": "candidate-context",
      "text": "For the official list, check the [TC39 repo](https://github.com/tc39/proposals). This list only contains all proposals higher than Stage 0 that are compilable by Babel. (If Stage 4, it will be in [preset-env](https://github.com/babel/babel/tree/master/packages/babel-preset-env))"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "tc39/test262",
      "status": "candidate-context",
      "text": "Official ECMAScript Conformance Test Suite"
    },
