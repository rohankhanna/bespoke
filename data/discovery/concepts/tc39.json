  "candidate_definitions": [
    {
      "source_kind": "repo-description",
      "source_repo": "babel/proposals",
      "status": "candidate-context",
      "text": "\u270d\ufe0f Tracking the status of Babel's implementation of TC39 proposals (may be out of date)"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "babel/proposals",
      "status": "candidate-context",
      "text": "For the official list, check the [TC39 repo](https://github.com/tc39/proposals). This list only contains all proposals higher than Stage 0 that are compilable by Babel. (If Stage 4, it will be in [preset-env](https://github.com/babel/babel/tree/master/packages/babel-preset-env))"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "tc39/test262",
      "status": "candidate-context",
      "text": "Official ECMAScript Conformance Test Suite"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "tc39/test262",
      "status": "candidate-context",
      "text": "Test262 is the implementation conformance test suite for the latest drafts (or most recent published edition) of the following Ecma specifications:"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "airbnb/javascript",
      "status": "candidate-context",
      "text": "JavaScript Style Guide"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "airbnb/javascript",
      "status": "candidate-context",
      "text": "*A mostly reasonable approach to JavaScript*"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "tc39/proposal-source-phase-imports",
      "status": "candidate-context",
      "text": "Proposal to enable importing modules at the source phase"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "tc39/proposal-source-phase-imports",
      "status": "candidate-context",
      "text": "Champion(s): Luca Casonato, Guy Bedford"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "tc39/proposal-pipeline-operator",
      "status": "candidate-context",
      "text": "A proposal for adding a useful pipe operator to JavaScript."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "tc39/proposal-pipeline-operator",
      "status": "candidate-context",
      "text": "* **Stage**: 2"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "tc39/proposal-function-helpers",
      "status": "candidate-context",
      "text": "A withdrawn proposal for standardizing some useful, popular helper functions into JavaScript\u2019s Function object."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "tc39/proposal-function-helpers",
      "status": "candidate-context",
      "text": "Withdrawn ECMAScript Stage-0 Proposal. J. S. Choi, 2021."
    },
    {
      "source_kind": "repo-description",
      "source_repo": "tc39/proposal-hack-pipes",
      "status": "candidate-context",
      "text": "Old specification for Hack pipes in JavaScript. Please go to the new specification."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "tc39/proposal-hack-pipes",
      "status": "candidate-context",
      "text": "ECMAScript Proposal. J. S. Choi, 2021."
    },
    {
      "source_kind": "repo-description",
      "source_repo": "tc39/proposal-call-this",
      "status": "candidate-context",
      "text": "A proposal for a simple call-this operator in JavaScript."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "tc39/proposal-call-this",
      "status": "candidate-context",
      "text": "ECMAScript Stage-1 Proposal. J. S. Choi, 2021."
    },
    {
      "source_kind": "repo-description",
      "source_repo": "tc39/proposal-function-pipe-flow",
      "status": "candidate-context",
      "text": "A proposal to standardize helper functions for serial function application and function composition."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "tc39/proposal-function-pipe-flow",
      "status": "candidate-context",
      "text": "ECMAScript Stage-0 Proposal (**withdrawn**). J. S. Choi, 2021."
    },
    {
      "source_kind": "repo-description",
      "source_repo": "js-choi/proposal-function-demethodize",
      "status": "candidate-context",
      "text": "Draft specification for a standard demethodize function in JavaScript."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "js-choi/proposal-function-demethodize",
      "status": "candidate-context",
      "text": "ECMAScript Stage-0 Proposal. J. S. Choi, 2022."
    },
    {
      "source_kind": "repo-description",
      "source_repo": "tc39/proposal-record-tuple",
      "status": "candidate-context",
      "text": "ECMAScript proposal for the Record and Tuple value types. | Stage 2: it will change!"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "tc39/proposal-record-tuple",
      "status": "candidate-context",
      "text": "> [!IMPORTANT]"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "bloomberg/record-tuple-polyfill",
      "status": "candidate-context",
      "text": "A polyfill for the ECMAScript Record and Tuple proposal."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "bloomberg/record-tuple-polyfill",
      "status": "candidate-context",
      "text": "The [Record and Tuple](https://github.com/tc39/proposal-record-tuple) ECMAScript proposal introduces new deeply immutable value types to JavaScript"
    }
  ],
