    {
      "source_kind": "repo-description",
      "source_repo": "micromatch/nanomatch",
      "status": "candidate-context",
      "text": "Fast, minimal glob matcher for node.js. Similar to micromatch, minimatch and multimatch, but without support for extended globs (extglobs), posix brackets or braces, and with complete Bash 4.3 wildcard support: (\"*\", \"**\", and \"?\")."
    },
    {
      "source_kind": "source-snippet",
