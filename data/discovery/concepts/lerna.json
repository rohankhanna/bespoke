  "candidate_definitions": [
    {
      "source_kind": "repo-description",
      "source_repo": "lerna/lerna",
      "status": "candidate-context",
      "text": "Lerna is a fast, modern build system for managing and publishing multiple JavaScript/TypeScript packages from the same repository."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "lerna/lerna",
      "status": "candidate-context",
      "text": "> **Important note: this project [changed stewardship to Nx](https://github.com/lerna/lerna/issues/3121)!**"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "lerna-lite/lerna-lite",
      "status": "candidate-context",
      "text": "Subset of Lerna in a smaller & more modular project. Help manage and publish multiple packages in a monorepo/workspace structure"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "lerna-lite/lerna-lite",
      "status": "candidate-context",
      "text": "<p>"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "atlassian/lerna-semantic-release",
      "status": "candidate-context",
      "text": "\ud83d\udce6:\ud83d\udee0\u2728\ud83d\udca5 \u2013 fully automated package publishing"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "atlassian/lerna-semantic-release",
      "status": "candidate-context",
      "text": "Status:"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "atlassian/cz-lerna-changelog",
      "status": "candidate-context",
      "text": "A commitizen adapter for the angular preset of https://github.com/conventional-changelog/conventional-changelog"
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "atlassian/cz-lerna-changelog",
      "status": "candidate-context",
      "text": "Version 2.0.0 is compatible with lerna version 3 only, if you need support for lerna 2 (more specifically, lerna 2.0.0.beta.31)."
    },
    {
      "source_kind": "repo-description",
      "source_repo": "invertase/melos",
      "status": "candidate-context",
      "text": "\ud83c\udf0b  A tool for managing Dart projects with multiple packages. With IntelliJ and Vscode IDE support. Supports automated versioning, changelogs & publishing via Conventional Commits."
    },
    {
      "source_kind": "source-snippet",
