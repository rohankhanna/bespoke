    {
      "source_kind": "repo-description",
      "source_repo": "gookit/filter",
      "status": "candidate-context",
      "text": "\u23f3 Provide filtering, sanitizing, and conversion of Golang data. \u63d0\u4f9b\u5bf9Golang\u6570\u636e\u7684\u8fc7\u6ee4\uff0c\u51c0\u5316\uff0c\u8f6c\u6362\u3002"
