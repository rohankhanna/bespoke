    {
      "source_kind": "repo-description",
      "source_repo": "BMW-InnovationLab/BMW-TensorFlow-Training-GUI",
      "status": "candidate-context",
      "text": "This repository allows you to get started with a gui based training a State-of-the-art Deep Learning model with little to no configuration needed! NoCode training with TensorFlow has never been so easy."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "BMW-InnovationLab/BMW-TensorFlow-Training-GUI",
      "status": "candidate-context",
      "text": "Updated for CUDA 11 and Tensorflow 2!!!"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "BMW-InnovationLab/BMW-YOLOv4-Training-Automation",
      "status": "candidate-context",
      "text": "This repository allows you to get started with training a state-of-the-art Deep Learning model with little to no configuration needed!  You provide your labeled dataset or label your dataset using our BMW-LabelTool-Lite and you can start the training right away and monitor it in many different ways like TensorBoard or a custom REST API and GUI. NoCode training with YOLOv4 and YOLOV3 has never been so easy."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "BMW-InnovationLab/BMW-YOLOv4-Training-Automation",
      "status": "candidate-context",
      "text": "This repository, based on AlexeyAB's darknet repro, allows you to get started with training a state-of-the-art Deep Learning model with little to no configuration needed! You provide your labeled dataset and you can start the training right away and monitor it in many different \u2026"
    },
    {
      "source_kind": "repo-description",
      "source_repo": "roboflow/maestro",
      "status": "candidate-context",
      "text": "streamline the fine-tuning process for multimodal models: PaliGemma 2, Florence-2, and Qwen2.5-VL"
    },
