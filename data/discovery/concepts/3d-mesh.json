    {
      "source_kind": "repo-description",
      "source_repo": "TimoBolkart/TF_FLAME",
      "status": "candidate-context",
      "text": "Tensorflow framework for the FLAME 3D head model. The code demonstrates how to sample 3D heads from the model, fit the model to 2D or 3D keypoints, and how to generate textured head meshes from Images."
    },
    {
      "source_kind": "source-snippet",
      "source_repo": "TimoBolkart/TF_FLAME",
      "status": "candidate-context",
      "text": "This is an official Tensorflow-based [FLAME](http://flame.is.tue.mpg.de/) repository."
    },
