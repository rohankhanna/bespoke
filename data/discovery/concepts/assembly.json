    {
      "source_kind": "repo-description",
      "source_repo": "minio/sha256-simd",
      "status": "candidate-context",
      "text": "Accelerate SHA256 computations in pure Go using  AVX512, SHA Extensions for x86 and ARM64 for ARM. On AVX512 it provides an up to 8x improvement (over 3 GB/s per core). SHA Extensions give a performance boost of close to 4x over native."
    },
    {
      "source_kind": "source-snippet",
